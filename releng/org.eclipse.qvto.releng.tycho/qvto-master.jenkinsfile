pipeline {
	agent {
		label 'ubuntu-latest'
	}
	
	triggers {
		cron('H 3 * * 0')
		pollSCM('H */6 * * 1-6')
	}

	options {
		buildDiscarder(logRotator(numToKeepStr: '5'))
		disableConcurrentBuilds()
		skipDefaultCheckout false
	}

	tools {
		maven 'apache-maven-latest'
		jdk 'openjdk-jdk21-latest'
	}

	environment {
		BUILD_TIMESTAMP = sh(returnStdout: true, script: 'date +%Y%m%d%H%M').trim()
	}
	
	parameters {
		choice(
			name: 'BUILD_TYPE',
			choices: ['nightly', 'milestone', 'reload'],
			description: '''
<ul>
<li> N - Nightly build
<li> S - Stable / Milestone build
Replay a Stable / Milestone qvto-promoter build to promote a Release. 
<li> reload - to reload the parameter definitions from GIT and bypass building
</ul>'''
		)
	}

	stages {
		//
		//	Set BUILD_TYPE in the Jenkins job description.
		//
		stage('Display Parameters') {
			steps {
				script {
					env.BUILD_TYPE = params.BUILD_TYPE
					echo "${params.BUILD_TYPE}"
					currentBuild.description = "${params.BUILD_TYPE}"
				}
			}
		}
		//
		//	Do the regular project build and test.
		//
		stage('Build') {
			when {
				expression { return params.BUILD_TYPE != 'reload' && currentBuild.getPreviousBuild() != null }
			}
			steps {
				wrap([$class: 'Xvnc', takeScreenshot: false, useXauthority: true]) {
					sh '''
						if [[ $BUILD_TYPE == 'milestone' ]]; then
							targetPhase='deploy'
						else
							targetPhase='verify'
						fi
						mvn	\
							-f releng/org.eclipse.qvto.releng.tycho/pom.xml \
							--no-transfer-progress \
							-DBUILD_TYPE=${BUILD_TYPE} \
							--show-version \
							clean \
							${targetPhase} \
							-P${BUILD_TYPE} \
							-Psign
						cd releng/org.eclipse.qvto.releng.build-site/target/repository
						zip -r ../../../../p2repo.zip .
						'''
				}
				archiveArtifacts allowEmptyArchive: true, artifacts: 'tests/*/target/**/surefire-reports/**/TEST-*.xml'
				archiveArtifacts allowEmptyArchive: true, artifacts: 'p2repo.zip'
			}
		}
		//
		//	Promote the build but only when the currentBuild is successful.
		//	Promote is delegated to a separate job so that a release can replay a milestone.
		//
		stage('Promote') {
			when {
				expression { return params.BUILD_TYPE != 'reload' && currentBuild.getPreviousBuild() != null }
			}
			steps {
				script {
					def List job_params = [
						string(name: '_BUILD_COMMIT', value: '-commit https://github.com/eclipse-qvto/org.eclipse.qvto/commit/' + env.GIT_COMMIT),
						string(name: '_BUILD_NUMBER', value: env.BUILD_NUMBER),
						string(name: '_BUILD_REMOTE', value: '-remote genie.qvt-oml@projects-storage.eclipse.org:/home/data/httpd/download.eclipse.org/mmt/qvto'),
						string(name: '_BUILD_ROOT', value: '/home/jenkins/agent/workspace/justj-promoter/justj-sync'),
						string(name: '_BUILD_TIMESTAMP', value: '-timestamp ' + env.BUILD_TIMESTAMP),
						string(name: '_BUILD_TYPE', value: env.BUILD_TYPE),
						string(name: '_BUILD_URL', value: env.BUILD_URL),
						string(name: '_JOB_NAME', value: env.JOB_NAME)
					]
					echo job_params.toString()
					build job: "qvto-promoter", parameters: job_params, wait: false, propagate: false
				}
			}
		}
	}

	post {
		failure {
			mail to: 'ed@willink.me.uk', subject: "[QVTo CI] Build Failure ${currentBuild.fullDisplayName}",
				mimeType: 'text/plain', body: "<${env.BUILD_URL}console>"
			archiveArtifacts allowEmptyArchive: true, artifacts: '**'
		}

		fixed {
			mail to: 'ed@willink.me.uk', subject: "[QVTo CI] Back to normal ${currentBuild.fullDisplayName}",
				mimeType: 'text/plain', body: "<${env.BUILD_URL}console>"
		}

		always {
			junit allowEmptyResults: params.BUILD_TYPE == 'reload' || currentBuild.getPreviousBuild() == null, testResults: '**/target/surefire-reports/**/TEST-*.xml'
		}

//		cleanup {
//			deleteDir()
//		}
	}
}
